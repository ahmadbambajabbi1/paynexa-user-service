# Copy to `.env` in this directory (gitignored).

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/escrow_users

# Phone auth: signed pre-auth tokens between SMS verify and PIN steps (min 16 chars in production)
AUTH_PREAUTH_SECRET=change-me-to-a-long-random-string-min-16-chars

# Twilio SMS (required for OTP delivery — no dev bypass)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Use either a Messaging Service SID or a Twilio phone number as sender:
TWILIO_MESSAGING_SERVICE_SID=
# TWILIO_FROM_NUMBER=+1234567890

# RabbitMQ (optional; service may fail open if unset — configure for your stack)
# RABBITMQ_URL=amqp://localhost:5672

# Service
PORT=5001

# Shared with admin-service: protects GET/POST /internal/admin/professional-kyc/*
USER_SERVICE_INTERNAL_ADMIN_SECRET=change-me-internal-admin-secret

# Cloudflare R2 — same bucket as product-service; used for POST /users/kyc/uploads (keys under kyc_uploads/)
# S3 API endpoint (Account ID in subdomain): https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Use R2 → Manage R2 API Tokens → Create API token → S3 credentials (not the cfat_ dashboard token for uploads).
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_REGION=auto
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
